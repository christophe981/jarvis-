# .env.example — Template public des variables d'environnement
# Copier ce fichier, le renommer en .env, et y renseigner les vraies valeurs.
# Ce fichier peut être commité : il ne contient aucune valeur sensible.

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Notion ---
NOTION_API_KEY=
NOTION_DATABASE_ID=

# --- Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_API_KEY=

# --- YouTube ---
YOUTUBE_API_KEY=

# --- Vercel ---
VERCEL_TOKEN=

# --- GitHub ---
GITHUB_TOKEN=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
